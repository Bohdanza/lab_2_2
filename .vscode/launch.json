{
    "version": "0.1.0",
    "configurations": [
        {
            "name": "DEBUG CLANG Build & Run",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Clang Debug build",
            "program": "${workspaceFolder}${config:debugBinaryPath}lab_2_2.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },

        {
            "name": "DEBUG MINGW Build & Run",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Mingw Debug build",
            "program": "${workspaceFolder}${config:debugBinaryPath}lab_2_2.exe",
            "cwd": "${workspaceFolder}",
            "externalConsole": true,
            "MIMode": "gdb", 
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                }
                ]
        }
    ]
}