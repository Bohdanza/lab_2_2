{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clang Debug build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}${config:debugBinaryPath} --preset Debug_clang -- -j 4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Clang Release build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}${config:releaseBinaryPath} --preset Release_clang -- -j 4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "CLANG RELEASE Run",
            "type": "shell",
            "dependsOn": "Clang Release build",
            "command": "./lab_2_2",
            "options": {
                "cwd": "${workspaceFolder}${config:releaseBinaryPath}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Mingw Debug build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}${config:debugBinaryPath} --preset Debug_mingw -- -j 4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Mingw Release build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}${config:releaseBinaryPath} --preset Release_mingw -- -j 4",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}