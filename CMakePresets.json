{
    "version": 8,
    "configurePresets": [
        {
            "hidden": true,
            "name": "base_config_mingw",
            "displayName": "Mingw base configuration",
            "description": "Serves as a base for Debug, Release and anything you wish for",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",    
            "cacheVariables": { 
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe"                                    
            }
        },
        {
            "hidden": false,
            "name": "Debug_config_mingw", 
            "displayName": "Mingw debug",
            "description": "It's debug!",
            "inherits": "base_config_mingw",
            "binaryDir": "${sourceDir}\\out\\build\\Debug\\",
            "cacheVariables": 
            {       
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "hidden": false,
            "name": "Release_config_mingw",
            "displayName": "Mingw release",
            "description": "It's release!",
            "inherits": "base_config_mingw",
            "binaryDir": "${sourceDir}\\out\\build\\Release\\",
            "cacheVariables": 
            {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },

        {
            "hidden": true,
            "name": "base_config_clang",
            "displayName": "Clang base configuration",
            "description": "Serves as a base for Debug, Release and anything you wish for",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",    
            "cacheVariables": { 
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "clang.exe",
                "CMAKE_CXX_COMPILER": "clang++.exe"                                    
            }
        },
        {
            "hidden": false,
            "name": "Debug_config_clang", 
            "displayName": "Clang debug",
            "description": "It's debug!",
            "inherits": "base_config_clang",
            "binaryDir": "${sourceDir}\\out\\build\\Debug\\",
            "cacheVariables": 
            {       
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "hidden": false,
            "name": "Release_config_clang",
            "displayName": "Clang release",
            "description": "It's release!",
            "inherits": "base_config_clang",
            "binaryDir": "${sourceDir}\\out\\build\\Release\\",
            "cacheVariables": 
            {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug_mingw",
            "displayName": "Mingw Debug",
            "configurePreset": "Debug_config_mingw"
        },
        {
            "name": "Release_mingw",
            "displayName": "Mingw Release",
            "configurePreset": "Release_config_mingw"
        },

        {
            "name": "Debug_clang",
            "displayName": "Clang Debug",
            "configurePreset": "Debug_config_clang"
        },
        {
            "name": "Release_clang",
            "displayName": "Clang Release",
            "configurePreset": "Release_config_clang"
        }
    ]
}